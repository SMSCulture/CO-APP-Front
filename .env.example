# CultureOwl Mobile — environment
# EXPO_PUBLIC_* variables are embedded in the client bundle. URLs only — never secrets.

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL_DEV=http://localhost:3001
EXPO_PUBLIC_API_URL_STAGING=https://staging-api.cultureowl.com
EXPO_PUBLIC_API_URL_PROD=https://api.cultureowl.com

# true = screens run on src/mock data; false = hit the GraphQL backend
EXPO_PUBLIC_USE_MOCK_DATA=true
